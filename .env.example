# =============================================================================
# ProjectNexus Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-generate-a-real-secret-key-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
POSTGRES_DB=projectnexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
DATABASE_URL=postgres://nexus:nexus_secret@db:5432/projectnexus

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Frontend
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000/ws

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@projectnexus.io

# File Upload
MAX_UPLOAD_SIZE_MB=10

# JWT Token Lifetime (minutes)
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=1440

# Sentry (optional, production)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
